{
  "id": "latency-monitor",
  "name": "Latency Monitor",
  "version": "1.0.2",
  "minNoctaliaVersion": "4.1.0",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "author": "Borhaneddine GUEMIDI <guemidiborhane@gmail.com>",
  "license": "MIT",
  "description": "Network latency monitor — multi-host, windowed averages, sparkline graphs",
  "tags": [
    "Bar",
    "Panel",
    "Network"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "hosts": [
        {
          "name": "Cloudflare DNS",
          "address": "1.1.1.1"
        },
        {
          "name": "Google DNS",
          "address": "8.8.8.8"
        }
      ],
      "intervalSeconds": 5,
      "thresholdGood": 20,
      "thresholdWarning": 70,
      "showHostName": true,
      "barHost": "worst",
      "colorGood": "#00ff7f",
      "colorWarning": "#f1fa8c",
      "colorCritical": "#ff5555",
      "animations": true
    }
  }
}
