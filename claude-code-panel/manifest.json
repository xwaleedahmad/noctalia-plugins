{
  "id": "claude-code-panel",
  "name": "Claude Code Panel",
  "version": "0.2.0",
  "minNoctaliaVersion": "4.1.2",
  "author": "d7om",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Claude Code (Anthropic agentic CLI) with full tool access, permission controls, session management, MCP servers, and device integration",
  "tags": [
    "Bar",
    "Panel",
    "AI",
    "Productivity"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "panel": {
      "defaultPosition": "right",
      "detached": true,
      "defaultHeightRatio": 0.9
    },
    "defaultSettings": {
      "maxHistoryLength": 200,
      "panelDetached": true,
      "panelPosition": "right",
      "panelHeightRatio": 0.9,
      "panelWidth": 620,
      "scale": 1,
      "attachmentStyle": "connected",
      "claude": {
        "binary": "claude",
        "workingDir": "",
        "model": "",
        "fallbackModel": "",
        "permissionMode": "default",
        "allowedTools": [],
        "disallowedTools": [],
        "additionalDirs": [],
        "mcpConfigPath": "",
        "appendSystemPrompt": "",
        "injectNoctaliaContext": true,
        "includePartialMessages": true,
        "dangerouslySkipPermissions": false,
        "sessionId": "",
        "autoResume": true,
        "maxTurns": 0,
        "strictMcpConfig": false,
        "requireConfirmBypass": true
      }
    }
  }
}