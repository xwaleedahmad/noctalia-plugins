{
  "id": "github-feed",
  "name": "GitHub Feed",
  "version": "1.3.1",
  "minNoctaliaVersion": "3.6.0",
  "author": "linuxmobile",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Display GitHub activity from users you follow and activity on your repos",
  "tags": [
    "Bar",
    "Panel",
    "Development",
    "Network"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "username": "",
      "token": "",
      "githubUrl": "",
      "refreshInterval": 1800,
      "maxEvents": 50,
      "showStars": true,
      "showForks": true,
      "showPRs": true,
      "showRepoCreations": true,
      "showMyRepoStars": true,
      "showMyRepoForks": true,
      "showNotificationBadge": true,
      "colorizationEnabled": false,
      "colorizationIcon": "Primary",
      "colorizationBadge": "Primary",
      "colorizationBadgeText": "Primary",
      "defaultTab": 0,
      "openInBrowser": true,
      "enableSystemNotifications": false,
      "notifyGitHubNotifications": true,
      "notifyStars": true,
      "notifyForks": true,
      "notifyPRs": true,
      "notifyRepoCreations": true,
      "notifyMyRepoStars": true,
      "notifyMyRepoForks": true
    }
  }
}
